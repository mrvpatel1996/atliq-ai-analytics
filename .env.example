# ============================================================
# Video Sync Service — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables marked REQUIRED must be set for the service to start.

# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development            # development | production | test

# ─── Database (PostgreSQL) ──────────────────────────────────
# REQUIRED
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/video_sync?schema=public"

# ─── Redis ──────────────────────────────────────────────────
# REQUIRED — Used by BullMQ for job queues
REDIS_URL="redis://localhost:6379"

# ─── Amazon S3 ──────────────────────────────────────────────
# REQUIRED
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=your-video-bucket

# Optional: custom endpoint (e.g., MinIO, LocalStack)
# S3_ENDPOINT=http://localhost:4566

# Multipart upload threshold in bytes (default: 100MB)
S3_MULTIPART_THRESHOLD=104857600

# ─── Vimeo ──────────────────────────────────────────────────
# REQUIRED — Create an app at https://developer.vimeo.com/apps
VIMEO_CLIENT_ID=your_vimeo_client_id
VIMEO_CLIENT_SECRET=your_vimeo_client_secret
VIMEO_ACCESS_TOKEN=your_vimeo_access_token

# Default privacy: anybody | nobody | contacts | password | unlisted | users
VIMEO_DEFAULT_PRIVACY=unlisted

# ─── Gumlet ─────────────────────────────────────────────────
# REQUIRED — Get your API key from https://www.gumlet.com/dashboard
GUMLET_API_KEY=your_gumlet_api_key

# Default collection ID for uploaded assets
GUMLET_COLLECTION_ID=your_collection_id

# ─── Cloudflare Stream ──────────────────────────────────────
# REQUIRED — https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Optional: signing key for signed URLs (base64 encoded)
# CLOUDFLARE_STREAM_SIGNING_KEY=

# ─── Webhook Security ────────────────────────────────────────
# Secret tokens to validate incoming webhooks (set in each platform's dashboard)
WEBHOOK_SECRET_VIMEO=your_vimeo_webhook_secret
WEBHOOK_SECRET_GUMLET=your_gumlet_webhook_secret
WEBHOOK_SECRET_CLOUDFLARE=your_cloudflare_webhook_secret

# Public base URL for webhook registration (no trailing slash)
PUBLIC_BASE_URL=https://your-domain.com

# ─── Sync Engine ────────────────────────────────────────────
# Comma-separated default destination platforms when not specified in job
SYNC_DEFAULT_DESTINATIONS=vimeo,gumlet,cloudflare

# Maximum concurrent sync jobs
SYNC_MAX_CONCURRENCY=5

# Retry config
SYNC_MAX_RETRIES=3
SYNC_RETRY_DELAY_MS=5000        # Initial backoff delay (exponential)

# ─── Auth / JWT ─────────────────────────────────────────────
# REQUIRED — Secret key for signing JWTs (min 32 chars, use a random string)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# JWT token expiry duration (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal
LOG_PRETTY=true                 # true in dev, false in prod (JSON output)
